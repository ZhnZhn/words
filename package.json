{
  "name": "words",
  "version": "0.4.0",
  "description": "Web app Words",
  "main": "index.js",
  "scripts": {
    "dev": "webpack serve --config webpack.dev.js",
    "dev:rspack": "rspack serve --config rspack.dev.js",
    "transpile": "babel ./src --out-dir ./js --source-maps --ignore test.js",
    "transpile:all": "babel ./src --out-dir ./js --source-maps",
    "lint:one": "eslint -c eslint.config.js",
    "lint:biome": "npx @biomejs/biome lint ./src --colors=off",
    "lint:only": "npx @biomejs/biome lint ./src --only=useSemanticElements --colors=off",
    "assist": "npx @biomejs/biome check ./src --formatter-enabled=false --linter-enabled=false --colors=off",
    "css:min": "node min-css.js",
    "build:dll": "webpack --color --progress --config webpack.dll.js",
    "build:dll-jsx": "webpack --color --progress --config webpack.dll-jsx.js",
    "build:prod": "webpack --color --progress --config webpack.prod.js",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "author": "Yevhenii Molodyi",
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZhnZhn/words.git"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "dompurify": "^3.4.1",
    "preact": "^10.29.1"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/plugin-transform-react-jsx": "^7.28.6",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "^7.29.3",
    "@babel/preset-react": "^7.28.5",
    "@biomejs/biome": "^2.4.14",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
    "@rspack/cli": "^1.7.11",
    "@rspack/core": "^1.7.11",
    "@swc/helpers": "^0.5.21",
    "babel-loader": "^10.1.1",
    "clean-css": "^5.3.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "html-webpack-plugin": "^5.6.7",
    "jest": "^30.3.0",
    "react-refresh": "^0.18.0",
    "terser-webpack-plugin": "^5.5.0",
    "webpack": "^5.106.2",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3"
  },
  "overrides": {
    "glob": "~13.0.6",
    "uuid": "~14.0.0"
  },
  "jest": {
    "roots": [
      "<rootDir>/js/flux/stores/",
      "<rootDir>/js/utils/"
    ],
    "transformIgnorePatterns": [
      "<rootDir>/js/flux/stores/",
      "<rootDir>/js/utils/"
    ]
  }
}
